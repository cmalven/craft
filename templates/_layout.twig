{# =============================================================== #}
{# Layout Template
{# =============================================================== #}

{% include '_partials/vite' ignore missing %}
{% import '_macros/theme' as theme %}

<!DOCTYPE html>
<html lang="en-US" class="{{ theme.classForEntry(entry ??? null) }} preload-transitions">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% include '_partials/head' %}
</head>

<body
  class="{{ bodyClass | default('') }}"
  data-module-lazy-image-transitioner
  data-module-debug-reveal
  data-module-resizer
  data-module-scroller
  hx-boost="true"
  hx-swap="outerHTML swap:0.3s settle:0.3s"
>
  <a class="skip-link" href="#main-content">Skip to content</a>

  {# Global Header #}
  {% include '_partials/global-header' %}

  <nav>
    {% for item in [
      { text: 'Home', url: '' },
      { text: 'One', url: 'one' },
      { text: 'Two', url: 'two' },
    ] %}
      <a
        href="/{{ item.url }}"
        {% if craft.app.request.pathInfo == item.url %}
          class="is-active"
        {% endif %}
      >{{ item.text }}</a>
    {% endfor %}
  </nav>

  {# Main Content Container #}
  <main class="l-container" tabindex="-1" id="main-content">
    <div data-module-reveal="up">

      {% block content %}{% endblock %}

      <!-- Counter -->
      <div
        data-module-counter
        data-counter-min="-10"
        data-counter-max="10"
      >
        <button data-counter="less">Less</button>
        <button data-counter="more">More</button>
      </div>

      <!-- Display -->
      <div data-module-display>
        <p data-display="count">0</p>
      </div>
    </div>

    {% include '_partials/debug-grid' %}
  </main>

  {# SVG #}
  <span class="h-hide-visually">
    {{ source('_svg/symbol/icon.symbol.svg', ignore_missing = true) }}
    {{ source('_svg/symbol/full.symbol.svg', ignore_missing = true) }}
  </span>

  {# Bug Tracking #}
  {% if getenv('CRAFT_ENVIRONMENT') == 'staging' %}
    {# TODO: Add scripts for bug-tracking software #}
  {% endif %}
</body>
</html>
